---
interface Props {
  productName: string;
  affiliateLink: string;
}

const { productName, affiliateLink } = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/60 backdrop-blur-xl">
  <nav class="container mx-auto flex items-center justify-between px-6 py-4 md:px-8">
    <a href="#" class="text-xl font-semibold tracking-tight text-white md:text-2xl">{productName}</a>
    <div class="hidden items-center gap-8 text-sm font-medium text-slate-300 md:flex">
      <a href="#features" class="transition hover:text-white">Features</a>
      <a href="#pricing" class="transition hover:text-white">Pricing</a>
      <a href="#review" class="transition hover:text-white">Review</a>
    </div>
    <a
      href={affiliateLink}
      target="_blank"
      rel="noopener sponsored"
      class="rounded-full bg-gradient-to-r from-indigo-500 to-violet-500 px-6 py-2.5 text-sm font-semibold text-white shadow-lg shadow-indigo-500/30 transition hover:translate-y-[-1px] hover:from-indigo-400 hover:to-violet-400"
    >
      Get Started
    </a>
  </nav>
</header>
